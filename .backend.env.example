# Copy to .backend.env and fill in (never commit .backend.env)

# GitHub Personal Access Token (classic) with repo scope
GITHUB_TOKEN=ghp_your_token_here

# owner/repo
GITHUB_REPO=np-design-git/training-dashboard

# File to update in the repo
GITHUB_FILE_PATH=training_log_active.md

# Branch to commit to
GITHUB_BRANCH=main
