# Copy this file to .env and fill in your GitHub raw URL
# Format: https://raw.githubusercontent.com/YOUR_USERNAME/YOUR_REPO/main/training_log_active.md
#
# How to get this URL:
# 1. Create a private GitHub repo (free at github.com)
# 2. Upload your training_log_active.md file
# 3. Open the file on GitHub → click "Raw" button → copy the URL from your browser
# 4. Paste it below

VITE_LOG_URL=https://raw.githubusercontent.com/YOUR_USERNAME/YOUR_REPO/main/training_log_active.md

# Note: For private repos, you'll need to either:
# - Make the repo public (simplest)
# - Use a GitHub Personal Access Token (see README for instructions)
